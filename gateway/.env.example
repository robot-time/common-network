DATABASE_URL=postgresql://localhost/common_network

# Referenced by name (never the raw key) from nodes.api_key_ref, e.g. OPENROUTER_API_KEY
OPENROUTER_API_KEY=

W_SIM=0.7
W_COST=0.15
W_LAT=0.15
REGION_BONUS=0.05

HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5
FORWARD_TIMEOUT_SECONDS=60

SEED_FILE=nodes.seed.yaml
SEED_ON_STARTUP=true
